# OpenAI API Key（必填）
OPENAI_API_KEY=

# 模型名称（可选，默认 gpt-4o-mini）
MODEL_NAME=gpt-4o-mini

# 自定义 API Base URL（可选，兼容 OpenAI 的 API）
# BASE_URL=https://api.openai.com/v1

# 服务端口（可选，默认 3001）
PORT=3001

# CORS 允许的来源（可选，不设置则允许所有来源）
# WEB_ORIGIN=http://localhost:5173

# API 访问令牌（可选，不设置则无鉴权）
# 设置后，POST/DELETE 危险接口需要 Authorization: Bearer <token>
# LAB_TOKEN=

# 前端访问令牌（可选，配合 LAB_TOKEN 使用）
# VITE_LAB_TOKEN=
