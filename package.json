{
  "name": "mcp-client-lab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "description": "MCP Client 实验项目 — 可视化观察工具调用链路",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:server": "pnpm --filter @mcp-client-lab/server dev",
    "dev:web": "pnpm --filter @mcp-client-lab/web dev",
    "dev:sse-demo": "pnpm --filter @mcp-client-lab/server dev:sse-demo",
    "dev:http-demo": "pnpm --filter @mcp-client-lab/server dev:http-demo",
    "dev": "concurrently -n server,web,sse,http -c blue,green,yellow,magenta \"pnpm dev:server\" \"pnpm dev:web\" \"pnpm dev:sse-demo\" \"pnpm dev:http-demo\"",
    "build:server": "pnpm --filter @mcp-client-lab/server build",
    "build:web": "pnpm --filter @mcp-client-lab/web build",
    "build": "pnpm build:server && pnpm build:web",
    "start": "pnpm --filter @mcp-client-lab/server start",
    "cli": "node packages/server/build/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "client",
    "debug"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "zod": "^3.25.76"
  }
}
